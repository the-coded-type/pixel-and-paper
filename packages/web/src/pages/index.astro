---
import "@core/styles/main.css";
---

<!doctype html>
<html>
    <head>
        <meta charset="utf-8" />
        <meta http-equiv="X-UA-Compatible" content="IE=edge" />
        <title>Pixel & Paper</title>
        <meta name="viewport" content="width=device-width, initial-scale=1" />

        <script>
            import { initLogger } from "../js/logging.js";
            import { createGeneratePdfButton } from "@core/ui/createGeneratePdfButton.js";
            import { createLoadDirectoryButton } from "../js/ui/createLoadDirectoryButton.js";
            import { createSaveDirectoryButton } from "../js/ui/createSaveDirectoryButton.js";
            import { createNewDirectoryButton } from "../js/ui/createNewDirectoryButton.js";

            // Tabs do not exist before creation, they should be returned on creation
            window.addEventListener("DOMContentLoaded", async () => {
                // Initialize window logger
                initLogger();

                console.log("Paper and Pixel loaded");

                const mainNav = document.getElementById("main-nav");

                // Initilize main nav
                if (mainNav) {
                    const newDirectoryButtonElement = createNewDirectoryButton(
                        mainNav,
                        "",
                        "new-project",
                        "NEW",
                    );

                    const loadDirectoryButtonElement =
                        createLoadDirectoryButton(
                            mainNav,
                            "ml-1",
                            "load-directory",
                            "LOAD",
                        );

                    const saveDirectoryButtonElement =
                        createSaveDirectoryButton(
                            mainNav,
                            "ml-1",
                            "save-directory",
                            "SAVE",
                        );

                    const generatePdfButtonElement = createGeneratePdfButton(
                        mainNav,
                        "ml-1 generate-pdf",
                        "generate-pdf",
                        "GENERATE PDF",
                    );
                }
            });

        </script>
    </head>
    <body id="body">
        <header>
            <h1>PIXEL AND PAPER</h1>
            <div style="margin-bottom: 2rem; display: flex; ">
                <nav id="main-nav"></nav>
                <span
                    class="ml-1"
                    style="margin-top: 1rem; display:block; color: orange;"
                    id="log">///</span
                >
            </div>
            <nav id="nav"></nav>
        </header>
        <main id="interface">
            <div id="tabs"></div>
        </main>
    </body>
</html>
