---
import Tab from "src/components/tab.astro";
---

<!doctype html>
<html>
    <head>
        <meta charset="utf-8" />
        <meta http-equiv="X-UA-Compatible" content="IE=edge" />
        <title>Page Title</title>
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link
            rel="stylesheet"
            type="text/css"
            media="screen"
            href="/styles/interface/main.css"
        />
        <script>
            import { createEditor } from "../js/createEditor";
            import { iframe } from "../js/iframe.js";

            import { markdown } from "@codemirror/lang-markdown";
            import { css } from "@codemirror/lang-css";

            const BASE_PATH = "/data/";

            const CONFIG = [
                { type: "css", name: "Page", data: ["page.css"] },
                { type: "css", name: "Setup", data: ["setup.css"] },
                { type: "css", name: "Interface", data: ["interface.css"] },
                { type: "css", name: "Variables", data: ["variables.css"] },
                { type: "css", name: "Typography", data: ["typogrphy.css"] },
                { type: "css", name: "Structure", data: ["structure.css"] },
                { type: "md", name: "Markdown", data: ["md.md"] },
            ];


            // Defining the interface object
            let INTERFACE = { preview: {lastScroll: 0} };

            const tabs = document.getElementById("tabs");

            let activeTab;

            let activeTabSelector;

            let activeTabIndex;

            const activeTabs = {};

            const languageMap = {
                css: css,
                md: markdown,
            };


            function debounce(func, wait) {
                let timeout;
                return function executedFunction(...args) {
                    const later = () => {
                        clearTimeout(timeout);
                        func(...args);
                    };
                    clearTimeout(timeout);
                    timeout = setTimeout(later, wait);
                };
            }

            const debouncedUpdatePreview = debounce(() => {
                updatePreview();
            }, 400);

            function openNewTab(_id, lang, content, className) {
                const container = document.createElement("div");
                container.className = `tab language-${lang} id-${_id} ${className}`;
                container.id = `container-${_id}`;

                tabs?.append(container);

                const langFn = languageMap[lang];

                activeTabs[_id] = createEditor(langFn(), content, container, debouncedUpdatePreview);

                return container;
            }

            const loadMyFile = async (filePath) => {
                try {
                    // Request the file from your local server
                    const response = await fetch(filePath);

                    // Convert the response to text
                    const content = await response.text();

                    return content;
                } catch (err) {
                    console.error("Error reading file:", err);
                }
            };

            /* /// NAVIGATION /// */

            const selectTab = (id) => {
                const allTabs = document.querySelectorAll(".tab");
                const allSelectors = document.querySelectorAll(".tab-selector");

                // Remove active from old
                allTabs.forEach((t) =>
                    t.classList.replace("active", "inactive"),
                );
                allSelectors.forEach((s) =>
                    s.classList.replace("active-tab", "inactive-tab"),
                );

                const targetTab = document.querySelector(`.id-${id}`);
                const targetSelector = document.querySelector(
                    `[data-id="${id}"]`,
                );

                if (targetTab && targetSelector) {
                    targetTab.classList.replace("inactive", "active");
                    targetSelector.classList.replace(
                        "inactive-tab",
                        "active-tab",
                    );
                    activeTabIndex = parseInt(id);

                    // CRITICAL: Tell CodeMirror to refresh its layout when shown
                    activeTabs[id]?.focus();
                }
            };

            // INIT INIT INIT INIT INIT INIT //
            ///////////////////////////////////

            async function initApp() {
                const PROMISES = CONFIG.map(async ({ type, name, data }) => {
                    const content = await loadMyFile(`${BASE_PATH}${data[0]}`);

                    return { type: type, name: name, data: content };
                });

                // DATA is an array of {type: 'type, for example css or md', data: 'string content'}
                const DATA = await Promise.all(PROMISES);

                const nav = document.getElementById("nav");

                DATA.forEach((d, index) => {
                    const className =
                        index == 0 ? "active-tab" : "inactive-tab";

                    nav.innerHTML += `<span style="margin-right:2em;" class="tab-selector ${className}" data-id="${index}">${index}.${d.name.toUpperCase()}</span>`;
                });

                nav.innerHTML += `<span class="tab-selector inactive-tab" data-id="${DATA.length}">S.PDF PREVIEW</span>`;

                DATA.forEach((d, index) => {
                    const className = index == 0 ? "active" : "inactive";
                    const lang = d.type || markdown;
                    openNewTab(index, lang, d.data, className);
                });

                const container = document.createElement("div");
                container.className = `tab inactive id-${DATA.length}`;

                const previewer = document.createElement("div");
                previewer.className = `tab-content`;
                previewer.id = "preview";

                container.appendChild(previewer);

                tabs?.append(container);

                //// INIT NAVIGATION /////
                const tabSelectors = document.querySelectorAll(".tab-selector");

                tabSelectors.forEach((tabSelector) => {
                    tabSelector.addEventListener("click", (e) => {
                        selectTab(e.target.dataset.id);
                    });
                });

                updatePreview();


            }

            //////////////////////////
            //////////////////////////
            //////////////////////////
            //// PREVIEW /////////////
            //////////////////////////
            //////////////////////////
            //////////////////////////

            async function updatePreview() {
                const previewTab = document.getElementById("preview");
                if (!previewTab) return;

                // 1. Get CSS
                const cssContent = Object.keys(activeTabs)
                    .filter((id) => {
                        const container = document.getElementById(
                            `container-${id}`,
                        );
                        // Safety: Check if activeTabs[id] exists AND has the class
                        return (
                            activeTabs[id] &&
                            container?.classList.contains("language-css")
                        );
                    })
                    .map((id) => activeTabs[id].state.doc.toString()) // Now safe
                    .join("\n");

                // 2. Get Markdown
                const mdTabId = Object.keys(activeTabs).find((id) => {
                    const container = document.getElementById(
                        `container-${id}`,
                    );
                    // Safety: Check if activeTabs[id] exists AND has the class
                    return (
                        activeTabs[id] &&
                        container?.classList.contains("language-md")
                    );
                });

                
                const mdContent = mdTabId
                    ? activeTabs[mdTabId].state.doc.toString()
                    : "";


                // 3. Update the iframe
                previewTab.innerHTML = await iframe(cssContent, mdContent);

                const iframeElement = previewTab.querySelector("iframe")

                if (iframeElement) {
                    iframeElement.onload = () => {
                        const internalIframeWindow = iframeElement.contentWindow;
                        
                        // The message iframeRendered is fired by the window when pagedJS has finished rendering the page, it's defined in iframe.js
                        window.addEventListener("message", (event) => {
                            if (event.data == "iframeRendered") {internalIframeWindow.scroll({top: INTERFACE.preview.lastScroll, behavior: "instant"} );}                            
                        })

                        
                        internalIframeWindow.addEventListener("scroll", (event) => {
                            INTERFACE.preview.lastScroll = internalIframeWindow.scrollY;
                            console.log('scroll Iframe', internalIframeWindow.scrollY)
                    })

                }
                }




                
            }

            initApp();
        </script>

        {
            /*
    <link rel='stylesheet' type='text/css' media='screen' href='/styles/interface/prism.css'>
    
    <link rel='stylesheet' type='text/css' media='screen' href='/styles/interface/custom-prism-css.css'>

*/
        }
    </head>
    <body id="body">
        <main id="interface">
            <h1>PIXEL AND PAPER</h1>
            <nav id="nav"></nav>

            <div id="tabs">
                {
                    /* <Tab tabName="CSS" tabId="tab-css" tabClass="language-css" /> */
                }
            </div>
        </main>
    </body>
</html>
