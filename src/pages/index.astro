---
import Tab from "src/components/tab.astro";
---

<!doctype html>
<html>
    <head>
        <meta charset="utf-8" />
        <meta http-equiv="X-UA-Compatible" content="IE=edge" />
        <title>Page Title</title>
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link
            rel="stylesheet"
            type="text/css"
            media="screen"
            href="/styles/interface/main.css"
        />
        <script>
            import {createEditor} from '../js/createEditor';
            import { markdown } from '@codemirror/lang-markdown'
            import { css } from "@codemirror/lang-css";

            const BASE_PATH = "/data/";

            const CONFIG = [
                { type: "css", name: "Page", data: ["page.css"] },
                { type: "css", name: "Setup", data: ["setup.css"] },
                { type: "css", name: "Interface", data: ["interface.css"] },
                { type: "css", name: "Variables", data: ["variables.css"] },
                { type: "css", name: "Typography", data: ["typogrphy.css"] },
                { type: "css", name: "Structure", data: ["structure.css"] },
                { type: "md", name: "Markdown", data: ["md.md"] },
            ];

            const activeTabs = {};

            const languageMap = {
                    'css': css,
                    'md': markdown
                };

            function openNewTab(id, lang, content, className) {
                console.log("lang", lang)
                const container = document.createElement("div");
                container.className = `tab language-${lang} id-${id} ${className}`;

                const tabs = document.getElementById("tabs");

                tabs?.append(container);

                const langFn = languageMap[lang];

                activeTabs[id] = createEditor(langFn(), content, container);

                return container;
            }

            const loadMyFile = async (filePath) => {
                    try {
                        // Request the file from your local server
                        const response = await fetch(filePath);

                        // Convert the response to text
                        const content = await response.text();

                        return content;
                    } catch (err) {
                        console.error("Error reading file:", err);
                    }
                };

            const PROMISES = CONFIG.map(async ({ type, name, data }) => {
                    const content = await loadMyFile(`${BASE_PATH}${data[0]}`);

                    return { type: type, name: name, data: content };
                });

            // DATA is an array of {type: 'type, for example css or md', data: 'string content'}
            const DATA = await Promise.all(PROMISES);

            const nav = document.getElementById("nav");

            DATA.forEach((d, index) => {
                    const className = index == 0 ? "active-tab" : "inactive-tab";

                    nav.innerHTML += `<span style="margin-right:2em;" class="tab-selector ${className}" data-id="${index}">${index}.${d.name.toUpperCase()}</span>`;
            });

            const tabs = document.getElementById("tabs");


            DATA.forEach((d, index) => {
                    const className = index == 0 ? "active" : "inactive";
                    const lang = d.type || markdown;
                    openNewTab(index, lang, d.data, className)

            })

          
        </script>

        {
            /*
    <link rel='stylesheet' type='text/css' media='screen' href='/styles/interface/prism.css'>
    
    <link rel='stylesheet' type='text/css' media='screen' href='/styles/interface/custom-prism-css.css'>

*/
        }

    </head>
    <body id="body">
        <main id="interface">
            <h1>PIXEL AND PAPER</h1>
            <nav id="nav"></nav>

            <div id="tabs">
                {
                    /* <Tab tabName="CSS" tabId="tab-css" tabClass="language-css" /> */
                }
            </div>
            

            <script  src='../js/main.js'></script>

    
        </main>
    </body>
</html>
