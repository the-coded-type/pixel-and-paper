<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Markdown + Paged.js with injected CSS</title>
    <style></style>
  <link rel="stylesheet" href="/styles/colors.css">
  <link rel="stylesheet" href="/styles/interface2.css">
  <link rel="stylesheet" href="/styles/global_tlb.css">
  <link rel="stylesheet" href="/styles/tlb.css">
  
    <script is:inline>
      window.PagedConfig = {
        auto: false,
        after: (flow) => {
          // You can add logic here that runs after Paged.js has completed its layout
          console.log("Paged.js flow completed:", flow);
        }
      };
    </script>

    <script src="/js/paged.polyfill.js" is:inline></script>

    <script type="module" is:inline>
      import { unified } from 'https://esm.sh/unified';
      import remarkParse from 'https://esm.sh/remark-parse';
      import remarkRehype from 'https://esm.sh/remark-rehype';
      import rehypeFormat from 'https://esm.sh/rehype-format';
      import rehypeStringify from 'https://esm.sh/rehype-stringify';

      async function renderMarkdown(file) {
        console.time('Total Time');  // Start total timing
        console.time('Markdown Fetch & Process');

        const res = await fetch(file);
        const md = await res.text();

        // Convert Markdown to HTML using unified
        const htmlText = await unified()
          .use(remarkParse) // Markdown to AST
          .use(remarkRehype) // AST to HTML
          .use(rehypeFormat) // Pretty print HTML
          .use(rehypeStringify) // Convert AST to string
          .process(md); // Wait for this step to complete

          console.timeEnd('Markdown Fetch & Process'); // End time for markdown fetch and processing


        // Set the processed HTML into the body
        document.body.innerHTML = String(htmlText);

        // Now that the content is in the DOM, trigger Paged.js preview
        console.time('Paged.js Flow');
        window.PagedPolyfill.preview(); // Trigger Paged.js here!
        console.timeEnd('Paged.js Flow');  // End timing for Paged.js flow

        console.timeEnd('Total Time'); // End the total time measurement


      }

      document.addEventListener('DOMContentLoaded', () => {
        renderMarkdown('./traveller.md'); // Change path to your markdown file
      });
    </script>
  </head>
  <body>
    {/* The experiment placeholder */}
    {/*
    <Experiment />
    */}
  </body>
</html>
